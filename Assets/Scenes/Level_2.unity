  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "GLOSARIO DE BESTIAS DEL RECORRIDO:\n\nMultiply -  vigila tu espalda, este
    conejo monstruoso puede aparecer por la puerta trasera. Ci\xE9rrala cuando le
    veas.\n\nLongstepper - si este ciervo tiene los ojso rojos, apaga la luz de la
    cabina. Si los tiene blancos, toca la ventana.\n\nBreak - cuando el jabal\xED
    mutante aparezca en las v\xEDas, apaga y enciende las luces repetidas veces.\n\nIberia
    - ignora a esta lechuza si tiene los ojos rojos. Si los tiene blancos, no lo
    pierdas de vista hasta que se vaya.\n\nPainless - si el toro aparece en las v\xEDas,
    reduce la valocidad o para el tren cuanto antes.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
