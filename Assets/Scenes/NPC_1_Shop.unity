  optionTexts:
  - {fileID: 575928676}
  - {fileID: 1605275346}
  - {fileID: 2108189746}
  - {fileID: 900031536}
  typingTime: 0.05
  nodes:
  - dialogueText: "Buenas noches, amigo. \xBFNecesitas surtirte de materiales? Tengo
      objetos que podr\xEDan serte \xFAtiles... siempre y cuando tengas la suficiente
      divisa, claro. \xBFC\xF3mo? \xBFQue los precios te parecen inflados? \xBFTu
      has visto c\xF3mo est\xE1n las cosas ah\xED fuera? No encontrar\xE1s a nadie
      m\xE1s en una larga distancia, as\xED que son lentejas. O las tomas, o te vas
      por donde has venido."
    options: []
    nextNodeIndex: 1
  - dialogueText: Echa un vistazo.
    options:
    - text: Cinta adhesiva
      nextNodeIndex: 2
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    - text: Item 2
      nextNodeIndex: 3
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    - text: Item 3
      nextNodeIndex: 4
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    - text: '"No hay nada que me interese"'
      nextNodeIndex: 5
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    nextNodeIndex: -1
  - dialogueText: Esa cinta es bastante buena.
    options:
    - text: Me la quedo
      nextNodeIndex: 6
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    - text: "\xBFQu\xE9 m\xE1s tienes?"
      nextNodeIndex: 1
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    nextNodeIndex: -1
  - dialogueText: Frase de item 2
    options:
    - text: Me la quedo
      nextNodeIndex: 6
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    - text: "\xBFQu\xE9 m\xE1s tienes?"
      nextNodeIndex: 1
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    nextNodeIndex: -1
  - dialogueText: Frase de item 3
    options:
    - text: Me la quedo
      nextNodeIndex: 6
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    - text: "\xBFQu\xE9 m\xE1s tienes?"
      nextNodeIndex: 1
      condition: 0
      requiredNode: 0
      endsDialogue: 0
    nextNodeIndex: -1
  - dialogueText: Hasta otra, amigo.
    options: []
    nextNodeIndex: -1
  - dialogueText: Un placer hacer negocios contigo.
    options: []
    nextNodeIndex: -1
