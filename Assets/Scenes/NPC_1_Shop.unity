--- !u!114 &1377416376
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1377416371}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff6d7ffdd44dde249bb3e3662ea100c7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 601498012}
  dialogueText: {fileID: 1718317798}
  actionBox: {fileID: 1425111415}
  optionButtons:
  - {fileID: 1977798642}
  - {fileID: 1074599356}
  - {fileID: 508997948}
  - {fileID: 489490407}
  optionTexts:
  - {fileID: 575928676}
  - {fileID: 1605275346}
  - {fileID: 2108189746}
  - {fileID: 900031536}
  typingTime: 0.05
  nodes:
  - dialogueText: "Buenas noches, amigo. \xBFNecesitas surtirte de materiales? Tengo
      objetos que podr\xEDan serte \xFAtiles... siempre y cuando tengas la suficiente
      divisa, claro. \xBFC\xF3mo? \xBFQue los precios te parecen inflados? \xBFTu
      has visto c\xF3mo est\xE1n las cosas ah\xED fuera? No encontrar\xE1s a nadie
      m\xE1s en una larga distancia, as\xED que son lentejas. O las tomas, o te vas
      por donde has venido."
    options: []
    nextNodeIndex: 1
  - dialogueText: Echa un vistazo.
    options:
    - text: Cinta adhesiva
      nextNodeIndex: 2
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    - text: Martillo
      nextNodeIndex: 3
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    - text: Metal brillante
      nextNodeIndex: 4
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    - text: '"No hay nada que me interese"'
      nextNodeIndex: 5
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    nextNodeIndex: -1
  - dialogueText: Esa cinta es bastante resistente, seguro que puedes arreglar algo
      con ella.
    options:
    - text: Me la quedo
      nextNodeIndex: 6
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 11400000, guid: 30d6bb5aeb26ad648817d12850170f4c, type: 2}
      noCoinNodeIndex: 7
      noSpaceNodeIndex: 8
    - text: "\xBFQu\xE9 m\xE1s tienes?"
      nextNodeIndex: 1
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    nextNodeIndex: -1
  - dialogueText: "Este martillo es algo simple, pero seguro que puede serte \xFAtil."
    options:
    - text: Me lo quedo
      nextNodeIndex: 6
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 11400000, guid: a8ce7beb1edf54e4c9da44ef8c315da6, type: 2}
      noCoinNodeIndex: 7
      noSpaceNodeIndex: 8
    - text: "\xBFQu\xE9 m\xE1s tienes?"
      nextNodeIndex: 1
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    nextNodeIndex: -1
  - dialogueText: "Es un trozo de metal que encontr\xE9 por ah\xED, \xBFa que es
      bonito?"
    options:
    - text: Me lo quedo
      nextNodeIndex: 6
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 11400000, guid: 6f5639d8342b9564ea33b4f787095acf, type: 2}
      noCoinNodeIndex: 7
      noSpaceNodeIndex: 8
    - text: "\xBFQu\xE9 m\xE1s tienes?"
      nextNodeIndex: 1
      condition: 0
      requiredNode: 0
      endsDialogue: 0
      itemToBuy: {fileID: 0}
      noCoinNodeIndex: -1
      noSpaceNodeIndex: -1
    nextNodeIndex: -1
  - dialogueText: Hasta otra, amigo.
    options: []
    nextNodeIndex: -1
  - dialogueText: Un placer hacer negocios contigo.
    options: []
    nextNodeIndex: -1
  - dialogueText: "\xBFMe tomas el pelo? Si no tienes suficiente dinero no me hagas
      perder el tiempo."
    options: []
    nextNodeIndex: -1
  - dialogueText: No parece que tengas suficiente espacio para guardar esto, colega.
    options: []
    nextNodeIndex: -1
  escena: 3
